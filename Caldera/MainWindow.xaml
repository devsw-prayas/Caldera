<Window x:Class="Caldera.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Caldera"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Border CornerRadius="12"
            ClipToBounds="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3a0a0a" Offset="0"/>
                <GradientStop Color="#1a0505" Offset="0.4"/>
                <GradientStop Color="#0a0005" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>

            <!-- watermark stack bottom left -->
            <StackPanel HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="20,0,0,10"
                        IsHitTestVisible="False"
                        Panel.ZIndex="0">
                <TextBlock Text="C++"
                           FontSize="120"
                           FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="#ff4020"
                           Opacity="0.06"
                           LineHeight="110"/>
                <TextBlock Text="ASM"
                           FontSize="120"
                           FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="#ff4020"
                           Opacity="0.06"
                           LineHeight="110"/>
                <TextBlock Text="CALDERA"
                           FontSize="120"
                           FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="#ff4020"
                           Opacity="0.06"
                           LineHeight="110"/>
            </StackPanel>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- title bar -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <TextBlock Text="🌋"
                                       FontSize="18"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Foreground="#ff4020"
                                       FontSize="14"
                                       FontWeight="Black"
                                       FontFamily="{StaticResource Orbitron}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0">
                                <TextBlock.Text>CALDERA</TextBlock.Text>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#ff4020"
                                                      BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="//  compiler explorer"
                                       Foreground="#5a3030"
                                       FontSize="11"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="—"
                                    Style="{StaticResource WindowButton}"
                                    Click="MinimizeButton_Click"/>
                            <Button Content="□"
                                    Style="{StaticResource WindowButton}"
                                    Click="MaximizeButton_Click"/>
                            <Button Content="✕"
                                    Style="{StaticResource CloseButton}"
                                    Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- toolbar -->
                <Border Grid.Row="1"
                        Margin="12,0,12,0"
                        BorderThickness="0,1,0,1">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#2a1010"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1a0808" Offset="0"/>
                            <GradientStop Color="#120505" Offset="0.5"/>
                            <GradientStop Color="#1a0808" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0">

                        <ComboBox x:Name="CompilerSelector"
                                  Width="120"
                                  Style="{StaticResource CalderaComboBox}"
                                  Margin="0,0,8,0">
                            <ComboBoxItem Content="clang++" IsSelected="True"/>
                            <ComboBoxItem Content="g++"/>
                            <ComboBoxItem Content="cl.exe"/>
                        </ComboBox>

                        <TextBox x:Name="FlagsInput"
                                 Width="320"
                                 Style="{StaticResource CalderaTextBox}"
                                 Text="-O3 -std=c++20 -madx -march=native"
                                 Margin="0,0,8,0"/>

                        <ComboBox x:Name="StdSelector"
                                  Width="100"
                                  Style="{StaticResource CalderaComboBox}"
                                  Margin="0,0,8,0">
                            <ComboBoxItem Content="c++23"/>
                            <ComboBoxItem Content="c++20" IsSelected="True"/>
                            <ComboBoxItem Content="c++17"/>
                            <ComboBoxItem Content="c++14"/>
                        </ComboBox>

                        <Button x:Name="RunButton"
                                Content="▶  Run"
                                Width="90"
                                Height="30"
                                Style="{StaticResource RunButton}"
                                Click="RunButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- editor panes -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- left pane: source -->
                    <Border Grid.Column="0"
                            Margin="12,8,6,12"
                            CornerRadius="10"
                            BorderThickness="1">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#ff4020" Opacity="0.3"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="#0d0505" Opacity="0.4"/>
                        </Border.Background>
                        <Grid>
                            <Border Height="36"
                                    VerticalAlignment="Top"
                                    CornerRadius="10,10,0,0"
                                    BorderThickness="0,0,0,1">
                                <Border.Background>
                                    <SolidColorBrush Color="#1a0a0a" Opacity="0.5"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#ff4020" Opacity="0.15"/>
                                </Border.BorderBrush>
                                <Grid Margin="12,0">
                                    <!-- left: badge -->
                                    <Border Background="#ff4020"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#ff4020"
                                                              BlurRadius="10"
                                                              ShadowDepth="0"
                                                              Opacity="0.8"/>
                                        </Border.Effect>
                                        <TextBlock Text="C++"
                                                   Foreground="#ffffff"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                    </Border>

                                    <!-- right: filename -->
                                    <TextBlock Text="source.cpp"
                                               Foreground="#5a3030"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBox x:Name="SourceEditor"
                                     Margin="0,36,0,0"
                                     Background="Transparent"
                                     Foreground="#e8d8d8"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     CaretBrush="#ff4020"
                                     SelectionBrush="#ff402040"
                                     Padding="12"/>
                        </Grid>
                    </Border>

                    <!-- splitter -->
                    <GridSplitter Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="#2a1010"/>

                    <!-- right pane: asm -->
                    <Border Grid.Column="2"
                            Margin="6,8,12,12"
                            CornerRadius="10"
                            BorderThickness="1">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#ff4020" Opacity="0.3"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="#0d0505" Opacity="0.4"/>
                        </Border.Background>
                        <Grid>
                            <Border Height="36"
                                    VerticalAlignment="Top"
                                    CornerRadius="10,10,0,0"
                                    BorderThickness="0,0,0,1">
                                <Border.Background>
                                    <SolidColorBrush Color="#1a0a0a" Opacity="0.5"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#ff4020" Opacity="0.15"/>
                                </Border.BorderBrush>
                                <Grid Margin="12,0">
                                    <!-- left: badge -->
                                    <Border Background="#2a1010"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="#ff4020"
                                            BorderThickness="1">
                                        <TextBlock Text="ASM"
                                                   Foreground="#ff4020"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                    </Border>

                                    <!-- right: filename -->
                                    <TextBlock Text="output.asm"
                                               Foreground="#5a3030"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBox x:Name="AsmOutput"
                                     Margin="0,36,0,0"
                                     Background="Transparent"
                                     Foreground="#e8d8d8"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="12"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
