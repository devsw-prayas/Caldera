<Window x:Class="Caldera.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:Caldera"
        Title="Caldera"
        Height="800"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Border x:Name="RootBorder"
            CornerRadius="12"
            ClipToBounds="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="GradStop0" Color="#5a0f0f" Offset="0"/>
                <GradientStop x:Name="GradStop1" Color="#2a0808" Offset="0.4"/>
                <GradientStop x:Name="GradStop2" Color="#0d0008" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- watermark -->
            <StackPanel HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="20,0,0,10"
                        IsHitTestVisible="False"
                        Panel.ZIndex="0">
                <TextBlock Text="C++"
                           FontSize="120" FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="{DynamicResource AccentBrush}"
                           Opacity="0.06" LineHeight="110"/>
                <TextBlock Text="ASM"
                           FontSize="120" FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="{DynamicResource AccentBrush}"
                           Opacity="0.06" LineHeight="110"/>
                <TextBlock Text="CALDERA"
                           FontSize="120" FontWeight="Black"
                           FontFamily="{StaticResource Orbitron}"
                           Foreground="{DynamicResource AccentBrush}"
                           Opacity="0.06" LineHeight="110"/>
            </StackPanel>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── TITLE BAR ── -->
                <Border Grid.Row="0" Background="#661a0505"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14" FontWeight="Black"
                                       FontFamily="{StaticResource Orbitron}"
                                       VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Text>CALDERA</TextBlock.Text>
                                <TextBlock.Effect>
                                    <DropShadowEffect x:Name="TitleGlow" Color="#ff4020"
                                                      BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="//  compiler explorer"
                                       Foreground="#7a5050"
                                       FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Text=" · "
                                       Foreground="#7a5050"
                                       FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TitleFileLabel"
                                       Foreground="#7a5050"
                                       FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="—" Style="{StaticResource WindowButton}" Click="MinimizeButton_Click"/>
                            <Button Content="□" Style="{StaticResource WindowButton}" Click="MaximizeButton_Click"/>
                            <Button Content="✕" Style="{StaticResource CloseButton}"  Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── MENU BAR ── -->
                <Border Grid.Row="1" Margin="12,0,12,0" BorderThickness="0,0,0,1">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                        <!-- File menu -->
                        <Grid>
                            <Button x:Name="FileMenuButton" Content="File"
                                    Style="{StaticResource MenuBarButton}"
                                    Click="FileMenuButton_Click"/>
                            <Popup x:Name="FileMenuPopup" StaysOpen="False"
                                   PlacementTarget="{Binding ElementName=FileMenuButton}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBgBrush}"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        MinWidth="200" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#000000" Opacity="0.6"/>
                                    </Border.Effect>
                                    <StackPanel Margin="4,6">
                                        <Button Content="New Tab          Ctrl+T" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="NewFile_Click"/>
                                        <Button Content="Open...          Ctrl+O" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="OpenFile_Click"/>
                                        <Button Content="Save             Ctrl+S" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="SaveFile_Click"/>
                                        <Button Content="Save As..."              Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="SaveAsFile_Click"/>
                                        <Border Height="1" Margin="8,4" Background="{DynamicResource BorderDimBrush}" Opacity="0.5"/>
                                        <Button Content="Export to HTML"         Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="ExportHtml_Click"/>
                                        <Button Content="Export to Markdown"     Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="ExportMarkdown_Click"/>
                                        <Border Height="1" Margin="8,4" Background="{DynamicResource BorderDimBrush}" Opacity="0.5"/>
                                        <Button Content="Share on Godbolt ↗"     Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="10,0" Click="GodboltButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Button Content="Preferences" Style="{StaticResource MenuBarButton}"
                                Click="PreferencesMenuButton_Click"/>
                        <Button Content="Help" Style="{StaticResource MenuBarButton}"
                                Click="HelpButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- ── TOOLBAR ── -->
                <Border Grid.Row="2" Margin="12,0,12,0" BorderThickness="0,0,0,1">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource PanelBg}" Offset="0"/>
                            <GradientStop Color="{DynamicResource BgMid}"   Offset="0.5"/>
                            <GradientStop Color="{DynamicResource PanelBg}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <ComboBox x:Name="CompilerSelector" Width="140"
                                  Style="{StaticResource CalderaComboBox}" Margin="0,0,8,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#40ff40"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Fill" Value="#ff4040"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" Foreground="#e0e0e0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- ── FLAGS INPUT + PICKER ── -->
                        <TextBox x:Name="FlagsInput" Width="300"
                                 Style="{StaticResource CalderaTextBox}"
                                 Text="-O3 -std=c++20 -madx -march=native"
                                 Margin="0,0,0,0"/>

                        <!-- Flag picker button + popup, anchored to a Grid so popup aligns -->
                        <Grid Margin="4,0,0,0">
                            <Button x:Name="FlagPickerButton"
                                    Content="▾ flags"
                                    Width="68" Height="30"
                                    Style="{StaticResource MenuBarButton}"
                                    Click="FlagPickerButton_Click"/>
                            <Popup x:Name="FlagPickerPopup"
                                   PlacementTarget="{Binding ElementName=FlagPickerButton}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBgBrush}"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="240"
                                        MaxHeight="380"
                                        Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                          Color="#000000" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="FlagGroupsControl" Margin="6,8,6,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <!-- Group -->
                                                    <StackPanel Margin="0,0,0,6">
                                                        <!-- Group header -->
                                                        <TextBlock Text="{Binding GroupName}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Margin="6,4,6,4"
                                                                   Opacity="0.8"/>
                                                        <!-- Flag items -->
                                                        <ItemsControl ItemsSource="{Binding Flags}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border x:Name="FlagItem"
                                                                            CornerRadius="4"
                                                                            Margin="2,1"
                                                                            Padding="8,5"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding Flag}"
                                                                            MouseLeftButtonDown="FlagItem_Click">
                                                                        <Border.Background>
                                                                            <SolidColorBrush Color="{DynamicResource BorderDim}" Opacity="0"/>
                                                                        </Border.Background>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding Flag}"
                                                                                       Foreground="#e0d0d0"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="13"
                                                                                       MinWidth="120"/>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding Description}"
                                                                                       Foreground="{DynamicResource TextDimBrush}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="10"
                                                                                       VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource BorderDimBrush}"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <!-- Separator under group (except last) -->
                                                        <Border Height="1" Margin="6,4,6,0"
                                                                Background="{DynamicResource BorderDimBrush}"
                                                                Opacity="0.5"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Preset picker -->
                        <Grid Margin="2,0,8,0">
                            <Button x:Name="PresetPickerButton"
                                    Content="▾ presets"
                                    Width="76" Height="30"
                                    Style="{StaticResource MenuBarButton}"
                                    Click="PresetPickerButton_Click"/>
                            <Popup x:Name="PresetPickerPopup"
                                   PlacementTarget="{Binding ElementName=PresetPickerButton}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBgBrush}"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        MinWidth="260" MaxHeight="300" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#000000" Opacity="0.6"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Button Content="＋ save current flags as preset"
                                                Style="{StaticResource MenuBarButton}"
                                                HorizontalContentAlignment="Left" Padding="10,0"
                                                Click="SavePresetButton_Click"/>
                                        <Border Height="1" Margin="8,2" Background="{DynamicResource BorderDimBrush}" Opacity="0.5"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                                        HorizontalScrollBarVisibility="Disabled" 
                                                        MaxHeight="240">
                                            <ItemsControl x:Name="PresetPickerList" Margin="6,4,6,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4" Margin="2,1" Padding="8,5"
                                                                Cursor="Hand" Tag="{Binding Description}"
                                                                MouseLeftButtonDown="PresetItem_Click">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource BorderDimBrush}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Flag}"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           FontFamily="Consolas" FontSize="12" MinWidth="80"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                                           Foreground="#c0b0b0" FontFamily="Consolas" FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <ComboBox x:Name="StdSelector" Width="100"
                                  Style="{StaticResource CalderaComboBox}" Margin="0,0,8,0">
                            <ComboBoxItem Content="c++23"/>
                            <ComboBoxItem Content="c++20" IsSelected="True"/>
                            <ComboBoxItem Content="c++17"/>
                            <ComboBoxItem Content="c++14"/>
                        </ComboBox>
                        <Button x:Name="RunButton" Content="▶  Run"
                                Width="90" Height="30"
                                Style="{StaticResource RunButton}"
                                Click="RunButton_Click"/>
                        <Button x:Name="AutoCompileToggle" Content="⏲ Auto: OFF"
                                Width="105" Height="30"
                                Style="{StaticResource MenuBarButton}"
                                Margin="4,0,0,0"
                                Click="AutoCompileToggle_Click"/>
                        <TextBox x:Name="McaFlagsInput" Width="200"
                                 Style="{StaticResource CalderaTextBox}"
                                 Text="--mcpu=native"
                                 ToolTip="llvm-mca arguments"
                                 Margin="12,0,0,0"/>

                        <!-- MCA flag picker -->
                        <Grid Margin="4,0,8,0">
                            <Button x:Name="McaFlagPickerButton"
                                    Content="▾ flags"
                                    Width="68" Height="30"
                                    Style="{StaticResource MenuBarButton}"
                                    Click="McaFlagPickerButton_Click"/>
                            <Popup x:Name="McaFlagPickerPopup"
                                   PlacementTarget="{Binding ElementName=McaFlagPickerButton}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBgBrush}"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="280"
                                        MaxHeight="380"
                                        Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                          Color="#000000" Opacity="0.6"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="McaFlagGroupsControl" Margin="6,8,6,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding GroupName}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Margin="6,4,6,4"
                                                                   Opacity="0.8"/>
                                                        <ItemsControl ItemsSource="{Binding Flags}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="4"
                                                                            Margin="2,1"
                                                                            Padding="8,5"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding Flag}"
                                                                            MouseLeftButtonDown="McaFlagItem_Click">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding Flag}"
                                                                                       Foreground="#e0d0d0"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="13"
                                                                                       MinWidth="150"/>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding Description}"
                                                                                       Foreground="{DynamicResource TextDimBrush}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="10"
                                                                                       VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="{DynamicResource BorderDimBrush}"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Border Height="1" Margin="6,4,6,0"
                                                                Background="{DynamicResource BorderDimBrush}"
                                                                Opacity="0.5"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <Button x:Name="McaButton" Content="⚙  MCA"
                                Width="90" Height="30"
                                Style="{StaticResource RunButton}"
                                Click="McaButton_Click"/>
                        <!-- MCA preset picker -->
                        <Grid Margin="2,0,0,0">
                            <Button x:Name="McaPresetPickerButton"
                                    Content="▾ presets"
                                    Width="76" Height="30"
                                    Style="{StaticResource MenuBarButton}"
                                    Click="McaPresetPickerButton_Click"/>
                            <Popup x:Name="McaPresetPickerPopup"
                                   PlacementTarget="{Binding ElementName=McaPresetPickerButton}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   StaysOpen="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBgBrush}"
                                        BorderBrush="{DynamicResource BorderMidBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        MinWidth="260" MaxHeight="300" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#000000" Opacity="0.6"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Button Content="＋ save current MCA flags as preset"
                                                Style="{StaticResource MenuBarButton}"
                                                HorizontalContentAlignment="Left" Padding="10,0"
                                                Click="SaveMcaPresetButton_Click"/>
                                        <Border Height="1" Margin="8,2" Background="{DynamicResource BorderDimBrush}" Opacity="0.5"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                            <ItemsControl x:Name="McaPresetPickerList" Margin="6,4,6,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4" Margin="2,1" Padding="8,5"
                                                                Cursor="Hand" Tag="{Binding Description}"
                                                                MouseLeftButtonDown="McaPresetItem_Click">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource BorderDimBrush}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Flag}"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           FontFamily="Consolas" FontSize="12" MinWidth="80"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                                           Foreground="#c0b0b0" FontFamily="Consolas" FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Button x:Name="InlineMcaButton" Content="⚡ annotate"
                                Width="90" Height="30"
                                Style="{StaticResource MenuBarButton}"
                                ToolTip="Inject llvm-mca latency annotations inline into ASM"
                                Margin="6,0,0,0"
                                Click="InlineMcaButton_Click"/>
                        <Button x:Name="CompareButton" Content="⊞ compare"
                                Width="100" Height="30"
                                Style="{StaticResource MenuBarButton}"
                                ToolTip="Compile with all compilers and show side-by-side ASM"
                                Margin="6,0,0,0"
                                Click="CompareButton_Click"/>
                        <Button Content="✕  Clear"
                                Width="80" Height="30"
                                Style="{StaticResource MenuBarButton}"
                                Margin="12,0,0,0"
                                Click="ClearButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- ── EDITOR + OUTPUT AREA ── -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition x:Name="SplitterRow" Height="5"/>
                        <RowDefinition x:Name="OutputRow" Height="0" MinHeight="0"/>
                    </Grid.RowDefinitions>

                    <!-- ── TOP: EDITOR PANES ── -->
                    <Grid Grid.Row="0" x:Name="EditorAreaGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5" x:Name="OpcodeSplitterCol"/>
                            <ColumnDefinition x:Name="OpcodeCol" Width="0" MinWidth="0" MaxWidth="600"/>
                        </Grid.ColumnDefinitions>

                        <!-- left: source tabs -->
                        <Border Grid.Column="0" Margin="12,8,6,12" CornerRadius="10" BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <!-- Tab strip header -->
                                <Border Height="36" VerticalAlignment="Top"
                                        CornerRadius="10,10,0,0" BorderThickness="0,0,0,1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource BgLight}" Opacity="0.3"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                    </Border.BorderBrush>
                                    <Grid Margin="8,0">
                                        <!-- Tabs row -->
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <StackPanel x:Name="TabStrip" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <ListBox x:Name="SourceTabControl"
                                                         SelectionChanged="SourceTabControl_SelectionChanged"
                                                         Background="Transparent" BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Border x:Name="TabBg" CornerRadius="4,4,0,0"
                                                                        Padding="10,4,6,4" Margin="2,0,0,0">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding DisplayName}"
                                                                                   Foreground="#c8c8c8"
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="13"
                                                                                   VerticalAlignment="Center"
                                                                                   MaxWidth="120"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <Button Grid.Column="1"
                                                                                Content="✕"
                                                                                DataContext="{Binding}"
                                                                                Click="CloseTab_Click"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Foreground="#666"
                                                                                FontSize="9"
                                                                                Padding="4,0,0,0"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <ContentPresenter/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                                <!-- New tab button -->
                                                <Button Content="＋" Style="{StaticResource MenuBarButton}"
                                                        Width="28" Padding="0"
                                                        Click="NewTabButton_Click"
                                                        VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                        <!-- C++ badge -->
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                                            </Border.Background>
                                            <TextBlock Text="C++" Foreground="#ffffff"
                                                       FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <avalon:TextEditor x:Name="SourceEditor"
                                         Margin="0,36,0,0"
                                         Background="Transparent" Foreground="#e8d8d8"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="14"
                                         ShowLineNumbers="True"
                                         WordWrap="False"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="12"/>
                            </Grid>
                        </Border>

                        <!-- vertical splitter -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch">
                            <GridSplitter.Background>
                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                            </GridSplitter.Background>
                        </GridSplitter>

                        <!-- right: asm -->
                        <Border Grid.Column="2" Margin="6,8,12,12" CornerRadius="10" BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <Border Height="36" VerticalAlignment="Top"
                                        CornerRadius="10,10,0,0" BorderThickness="0,0,0,1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource BgLight}" Opacity="0.3"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                    </Border.BorderBrush>
                                    <Grid Margin="12,0">
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                                            </Border.BorderBrush>
                                            <TextBlock Text="ASM" Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                        </Border>
                                        <!-- Stats label -->
                                        <TextBlock x:Name="AsmStatsLabel"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Margin="52,0,0,0"/>
                                        <!-- Search box -->
                                        <TextBox x:Name="AsmSearchBox"
                                                 Width="120" Height="22"
                                                 HorizontalAlignment="Right"
                                                 Margin="0,0,298,0"
                                                 Style="{StaticResource CalderaTextBox}"
                                                 FontSize="11"
                                                 ToolTip="Filter ASM (mnemonic / text)"
                                                 TextChanged="AsmSearchBox_TextChanged"/>
                                        <TextBlock Text="output.asm"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="13" FontFamily="Consolas"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <Button Content="⎘ copy"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,80,0"
                                                Style="{StaticResource MenuBarButton}"
                                                FontSize="10" Height="22"
                                                Click="CopyAsmButton_Click"/>
                                        <Button x:Name="PinButton"
                                                Content="⊞ pin"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,140,0"
                                                Style="{StaticResource MenuBarButton}"
                                                FontSize="10" Height="22"
                                                ToolTip="Pin current ASM as baseline for diff"
                                                Click="UnpinOrPin_Click"/>
                                        <Button x:Name="OpcodeRefToggle"
                                                Content="⊞ ref"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,195,0"
                                                Style="{StaticResource MenuBarButton}"
                                                FontSize="10" Height="22"
                                                Click="OpcodeRefToggle_Click"/>
                                    </Grid>
                                </Border>
                                <avalon:TextEditor x:Name="AsmOutput"
                                         Margin="0,36,0,0"
                                         Background="Transparent" Foreground="#e8d8d8"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="14"
                                         SyntaxHighlighting="ASM"
                                         ShowLineNumbers="True"
                                         WordWrap="False"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Auto"
                                         IsReadOnly="True"
                                         Padding="12"/>
                            </Grid>
                        </Border>
                        <!-- opcode splitter -->
                        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                                      x:Name="OpcodePanelSplitter">
                            <GridSplitter.Background>
                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                            </GridSplitter.Background>
                        </GridSplitter>

                        <!-- opcode reference panel -->
                        <local:OpcodePanel x:Name="OpcodeRefPanel"
                                           Grid.Column="4"
                                           Margin="0,8,12,12"/>

                    </Grid>

                    <!-- ── HORIZONTAL SPLITTER (hidden until output opens) ── -->
                    <GridSplitter x:Name="OutputSplitter"
                                  Grid.Row="1"
                                  Height="5" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Visibility="Collapsed">
                        <GridSplitter.Background>
                            <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                        </GridSplitter.Background>
                    </GridSplitter>

                    <!-- ── BOTTOM: OUTPUT PANELS ── -->
                    <Grid x:Name="OutputPanel"
                          Grid.Row="2"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- left: compiler errors -->
                        <Border Grid.Column="0" Margin="12,4,6,12" CornerRadius="10" BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <Border Height="36" VerticalAlignment="Top"
                                        CornerRadius="10,10,0,0" BorderThickness="0,0,0,1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource BgLight}" Opacity="0.3"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                    </Border.BorderBrush>
                                    <Grid Margin="12,0">
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                                            </Border.BorderBrush>
                                            <TextBlock Text="OUTPUT" Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="compiler output"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="13" FontFamily="Consolas"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <TextBox x:Name="CompilerOutput"
                                         Margin="0,36,0,0"
                                         Background="Transparent" Foreground="#e8d8d8"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="13"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="12"/>
                            </Grid>
                        </Border>

                        <!-- output splitter -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch">
                            <GridSplitter.Background>
                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                            </GridSplitter.Background>
                        </GridSplitter>

                        <!-- right: llvm-mca -->
                        <Border Grid.Column="2" Margin="6,4,12,12" CornerRadius="10" BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <Border Height="36" VerticalAlignment="Top"
                                        CornerRadius="10,10,0,0" BorderThickness="0,0,0,1">
                                    <Border.Background>
                                        <SolidColorBrush Color="{DynamicResource BgLight}" Opacity="0.3"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                                    </Border.BorderBrush>
                                    <Grid Margin="12,0">
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                                            </Border.BorderBrush>
                                            <TextBlock Text="LLVM-MCA" Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="analysis"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="13" FontFamily="Consolas"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Grid Margin="0,36,0,0">
                                    <TextBox x:Name="McaOutputRaw"
                                             Background="Transparent" Foreground="#e8d8d8"
                                             BorderThickness="0" FontFamily="Consolas" FontSize="13"
                                             IsReadOnly="True" AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             Padding="12" Visibility="Collapsed" />
                                    
                                    <Grid x:Name="McaOutputGrid" Visibility="Visible">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        
                                        <TextBox x:Name="McaSummaryText" 
                                                 Grid.Row="0"
                                                 Background="Transparent" Foreground="#e8d8d8"
                                                 BorderThickness="0" FontFamily="Consolas" FontSize="13"
                                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 Padding="12,12,12,6" />

                                        <DataGrid x:Name="McaDataGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  Background="Transparent"
                                                  RowBackground="Transparent"
                                                  Foreground="#e8d8d8"
                                                  HeadersVisibility="Column"
                                                  BorderThickness="0"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="#303030"
                                                  IsReadOnly="True"
                                                  Margin="12,0,12,12">
                                            <DataGrid.Resources>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#151515"/>
                                                    <Setter Property="Foreground" Value="#a0a0a0"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </Style>
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="uOps" Binding="{Binding UOps}" Width="60" />
                                                <DataGridTextColumn Header="Latency" Binding="{Binding Latency}" Width="70" />
                                                <DataGridTextColumn Header="RThroughput" Binding="{Binding RThroughput}" Width="100" />
                                                <DataGridTextColumn Header="Instruction" Binding="{Binding Instruction}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
