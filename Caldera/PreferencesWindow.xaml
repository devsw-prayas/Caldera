<Window x:Class="Caldera.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Width="540" Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border x:Name="RootBorder"
            CornerRadius="10" BorderThickness="1"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border.BorderBrush>
            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.35"/>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource BgLight}" Offset="0"/>
                <GradientStop Color="{DynamicResource BgDark}"  Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- title bar -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Background="#661a0505" BorderThickness="0,0,0,1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <Grid Margin="14,0">
                    <TextBlock Text="Preferences"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Style="{StaticResource CloseButton}"
                            Click="ClosePrefs_Click"/>
                </Grid>
            </Border>

            <!-- content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,8">

                    <!-- THEME SECTION -->
                    <TextBlock Text="THEME"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource Orbitron}"
                               Margin="0,0,0,10"/>

                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <!-- Corium -->
                        <Border x:Name="ThemeCorium" Width="108" Height="64" CornerRadius="7"
                                Margin="0,0,8,8" Cursor="Hand" Tag="Corium"
                                MouseLeftButtonDown="Theme_Click" BorderThickness="2">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#ff4020" Opacity="0.6"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3a0a0a" Offset="0"/>
                                    <GradientStop Color="#0a0005" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="CORIUM" Foreground="#ff4020"
                                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                                <Border Width="40" Height="4" CornerRadius="2" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#ff4020"/>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Iota -->
                        <Border x:Name="ThemeIota" Width="108" Height="64" CornerRadius="7"
                                Margin="0,0,8,8" Cursor="Hand" Tag="Iota"
                                MouseLeftButtonDown="Theme_Click" BorderThickness="2">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00bcd4" Opacity="0.4"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a1a2a" Offset="0"/>
                                    <GradientStop Color="#020d15" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="IOTA" Foreground="#00bcd4"
                                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                                <Border Width="40" Height="4" CornerRadius="2" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#00bcd4"/>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- StormSTL -->
                        <Border x:Name="ThemeStormSTL" Width="108" Height="64" CornerRadius="7"
                                Margin="0,0,8,8" Cursor="Hand" Tag="StormSTL"
                                MouseLeftButtonDown="Theme_Click" BorderThickness="2">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4caf50" Opacity="0.4"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0a1f0a" Offset="0"/>
                                    <GradientStop Color="#020a02" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="STORMSTL" Foreground="#4caf50"
                                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                                <Border Width="40" Height="4" CornerRadius="2" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#4caf50"/>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Spectra -->
                        <Border x:Name="ThemeSpectra" Width="108" Height="64" CornerRadius="7"
                                Margin="0,0,8,8" Cursor="Hand" Tag="Spectra"
                                MouseLeftButtonDown="Theme_Click" BorderThickness="2">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#ffc107" Opacity="0.4"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1f1200" Offset="0"/>
                                    <GradientStop Color="#0a0700" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="SPECTRA" Foreground="#ffc107"
                                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"/>
                                <Border Width="40" Height="4" CornerRadius="2" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#ffc107"/>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- FONT SECTION -->
                    <TextBlock Text="EDITOR FONT"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource Orbitron}"
                               Margin="0,0,0,10"/>

                    <!-- Font family -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Font Family"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox x:Name="FontFamilyPicker" Grid.Column="1"
                                  Style="{StaticResource CalderaComboBox}"
                                  SelectionChanged="FontFamilyPicker_SelectionChanged"/>
                    </Grid>

                    <!-- Font size -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Font Size"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <Slider x:Name="FontSizeSlider" Grid.Column="1"
                                Minimum="9" Maximum="24" Value="13"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="FontSizeSlider_ValueChanged"/>
                        <TextBlock x:Name="FontSizeLabel" Grid.Column="2" Text="13"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Output pane font size -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Output Size"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <Slider x:Name="OutputFontSizeSlider" Grid.Column="1"
                                Minimum="9" Maximum="24" Value="12"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"
                                ValueChanged="OutputFontSizeSlider_ValueChanged"/>
                        <TextBlock x:Name="OutputFontSizeLabel" Grid.Column="2" Text="12"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Preview -->
                    <Border CornerRadius="6" BorderThickness="1" Padding="12,8" Margin="0,4,0,0">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.2"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.6"/>
                        </Border.Background>
                        <TextBlock x:Name="FontPreview"
                                   Text="int main() { return 0; } // preview"
                                   Foreground="#e8d8d8"
                                   FontFamily="Consolas" FontSize="13"/>
                    </Border>

                    <!-- COMPILER PATHS SECTION -->
                    <TextBlock Text="COMPILER PATHS"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource Orbitron}"
                               Margin="0,20,0,4"/>
                    <TextBlock Text="Leave blank to invoke via PATH (cmd fallback)"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontFamily="Consolas" FontSize="10"
                               Margin="0,0,0,10"/>

                    <!-- clang++ -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="clang++"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="ClangPath" Grid.Column="1"
                                 Style="{StaticResource CalderaTextBox}"
                                 Height="28" FontSize="11"
                                 ToolTip="Full path to clang++.exe — leave blank to use PATH"/>
                        <Button Grid.Column="2" Content="…" Height="28"
                                Style="{StaticResource MenuBarButton}"
                                Padding="0" Margin="4,0,0,0"
                                Click="BrowseClang_Click"/>
                    </Grid>

                    <!-- g++ -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="g++"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="GppPath" Grid.Column="1"
                                 Style="{StaticResource CalderaTextBox}"
                                 Height="28" FontSize="11"
                                 ToolTip="Full path to g++.exe — leave blank to use PATH"/>
                        <Button Grid.Column="2" Content="…" Height="28"
                                Style="{StaticResource MenuBarButton}"
                                Padding="0" Margin="4,0,0,0"
                                Click="BrowseGpp_Click"/>
                    </Grid>

                    <!-- cl.exe -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="cl.exe"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="ClPath" Grid.Column="1"
                                 Style="{StaticResource CalderaTextBox}"
                                 Height="28" FontSize="11"
                                 ToolTip="Full path to cl.exe — leave blank to use PATH"/>
                        <Button Grid.Column="2" Content="…" Height="28"
                                Style="{StaticResource MenuBarButton}"
                                Padding="0" Margin="4,0,0,0"
                                Click="BrowseCl_Click"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- footer -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                            Style="{StaticResource MenuBarButton}"
                            Click="ClosePrefs_Click"/>
                    <Button Content="Apply" Width="80" Height="28"
                            Style="{StaticResource RunButton}"
                            Click="ApplyPrefs_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
