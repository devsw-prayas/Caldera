<Window x:Class="Caldera.UnsavedChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unsaved Changes"
        Width="380" Height="160"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="10" BorderThickness="1"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border.BorderBrush>
            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.35"/>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource BgLight}" Offset="0"/>
                <GradientStop Color="{DynamicResource BgDark}"  Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Background="#44000000" BorderThickness="0,0,0,1">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <TextBlock Text="UNSAVED CHANGES"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14,0"/>
            </Border>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Foreground="#cccccc"
                       FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       TextWrapping="Wrap"
                       Margin="18,0,18,0"/>

            <!-- Buttons -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                    <Button x:Name="CancelBtn" Content="Cancel" Width="72" Height="26"
                            Margin="0,0,6,0" Style="{StaticResource MenuBarButton}"
                            Click="Cancel_Click"/>
                    <Button x:Name="NoBtn"     Content="Discard" Width="72" Height="26"
                            Margin="0,0,6,0" Style="{StaticResource MenuBarButton}"
                            Click="No_Click"/>
                    <Button x:Name="YesBtn"    Content="Save" Width="72" Height="26"
                            Style="{StaticResource RunButton}"
                            Click="Yes_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
