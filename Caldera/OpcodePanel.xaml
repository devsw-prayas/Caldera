<UserControl x:Class="Caldera.OpcodePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="10" BorderThickness="1">
        <Border.BorderBrush>
            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.3"/>
        </Border.BorderBrush>
        <Border.Background>
            <SolidColorBrush Color="{DynamicResource PanelBgDark}" Opacity="0.4"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" BorderThickness="0,0,0,1">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource BgLight}" Opacity="0.3"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="3" Padding="6,2" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                            </Border.BorderBrush>
                            <TextBlock Text="REF" Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock x:Name="HeaderMnemonic"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="14" FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="HeaderCategory"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="14" FontFamily="Consolas"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ContentPanel" Margin="14,12,14,14">

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState">
                        <TextBlock Text="hover an instruction"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,40,0,4"/>
                        <TextBlock Text="in the ASM pane"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- COMPACT VIEW -->
                    <StackPanel x:Name="CompactView" Visibility="Collapsed">

                        <TextBlock x:Name="SummaryText"
                                   Foreground="#d8d0d0" FontFamily="Consolas" FontSize="14"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <!-- Flags -->
                        <Border CornerRadius="6" BorderThickness="1" Padding="10,8" Margin="0,0,0,10">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBg}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="READS" Foreground="{DynamicResource TextDimBrush}"
                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="FlagsReadText"
                                               Foreground="#c0b8b8" FontFamily="Consolas" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="WRITES" Foreground="{DynamicResource TextDimBrush}"
                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="FlagsWriteText"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontFamily="Consolas" FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Latency hint -->
                        <Border CornerRadius="6" BorderThickness="1" Padding="10,8" Margin="0,0,0,12">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBg}" Opacity="0.4"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LAT / TPUT" Foreground="{DynamicResource TextDimBrush}"
                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="LatencyHintText"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="LatencyUarchText"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           FontFamily="Consolas" FontSize="14"
                                           VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </Grid>
                        </Border>

                        <Button x:Name="ExpandButton"
                                Content="▾  show more"
                                Style="{StaticResource MenuBarButton}"
                                FontSize="14" Height="24"
                                HorizontalAlignment="Left"
                                Click="ExpandButton_Click"/>
                    </StackPanel>

                    <!-- EXPANDED VIEW -->
                    <StackPanel x:Name="ExpandedView" Visibility="Collapsed">

                        <TextBlock x:Name="DescriptionText"
                                   Foreground="#c0b8b8" FontFamily="Consolas" FontSize="14"
                                   TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,14"/>

                        <Border Height="1" Margin="0,0,0,14" Opacity="0.35">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                            </Border.Background>
                        </Border>

                        <!-- Operand forms -->
                        <TextBlock Text="OPERAND FORMS"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <ItemsControl x:Name="FormsControl" Margin="0,0,0,14">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,6" Margin="0,2,0,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource PanelBg}" Opacity="0.5"/>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Operands}"
                                                           Foreground="#d8d0d0"
                                                           FontFamily="Consolas" FontSize="14"/>
                                                <TextBlock Text="{Binding OpcodeBytes}"
                                                           Foreground="{DynamicResource TextDimBrush}"
                                                           FontFamily="Consolas" FontSize="14"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="3" Padding="5,2"
                                                    VerticalAlignment="Center" Margin="6,0,0,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{DynamicResource BorderDim}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Encoding}"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Latency table -->
                        <TextBlock Text="LATENCY TABLE"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <Border CornerRadius="6" BorderThickness="1" Margin="0,0,0,14" Padding="0,4">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource PanelBg}" Opacity="0.4"/>
                            </Border.Background>
                            <StackPanel>
                                <!-- Column headers -->
                                <Grid Margin="10,4,10,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="64"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="µARCH"  Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="LAT"    Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="TPUT"   Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="PORTS"  Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <ItemsControl x:Name="LatencyControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BorderDimBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="64"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Uarch}"
                                                               Foreground="#c0b8b8" FontFamily="Consolas" FontSize="14"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Latency}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Throughput}"
                                                               Foreground="#c0b8b8" FontFamily="Consolas" FontSize="14"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Ports}"
                                                               Foreground="{DynamicResource TextDimBrush}"
                                                               FontFamily="Consolas" FontSize="14"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Exceptions -->
                        <TextBlock Text="EXCEPTIONS"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="ExceptionText"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontFamily="Consolas" FontSize="14"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Button x:Name="CollapseButton"
                                Content="▴  show less"
                                Style="{StaticResource MenuBarButton}"
                                FontSize="14" Height="24"
                                HorizontalAlignment="Left"
                                Click="CollapseButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
